rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ══════════════════════════════════════════
    // TEAMS COLLECTION
    // ══════════════════════════════════════════
    match /teams/{teamId} {
      // Anyone can create a team (registration)
      allow create: if request.auth != null
        && request.auth.uid == teamId
        && request.resource.data.keys().hasAll(['teamName', 'members', 'createdAt'])
        && request.resource.data.teamName is string
        && request.resource.data.members is list
        && request.resource.data.members.size() >= 3
        && request.resource.data.members.size() <= 4;

      // Only the team can read their own data
      allow read: if request.auth != null
        && request.auth.uid == teamId;

      // Only server (admin SDK) should update team docs
      // Client can update their own sessionId field only
      allow update: if request.auth != null
        && request.auth.uid == teamId
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['sessionId']);

      allow delete: if false;
    }

    // ══════════════════════════════════════════
    // CHALLENGES COLLECTION
    // ══════════════════════════════════════════
    match /challenges/{challengeId} {
      // Any authenticated user can read challenges
      // IMPORTANT: The 'answer' field is NOT stored here — it's in a
      // separate answers collection readable only by Cloud Functions
      allow read: if request.auth != null;

      // Only admin can write challenges
      allow write: if false; // Use Firebase Admin SDK or Console
    }

    // ══════════════════════════════════════════
    // CHALLENGE ANSWERS (server-side only)
    // ══════════════════════════════════════════
    match /challenge_answers/{challengeId} {
      // NEVER readable by clients — only Cloud Functions
      allow read, write: if false;
    }

    // ══════════════════════════════════════════
    // SESSIONS COLLECTION
    // ══════════════════════════════════════════
    match /sessions/{sessionId} {
      // Team can read their own sessions
      allow read: if request.auth != null
        && resource.data.teamId == request.auth.uid;

      // Team can create a session for themselves
      allow create: if request.auth != null
        && request.resource.data.teamId == request.auth.uid
        && request.resource.data.keys().hasAll(['teamId', 'startTime', 'endTime', 'score', 'isActive']);

      // Score updates MUST come from Cloud Functions (server-side)
      // Client can only update activeChallengeId
      allow update: if request.auth != null
        && resource.data.teamId == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['activeChallengeId']);

      allow delete: if false;
    }

    // ══════════════════════════════════════════
    // SUBMISSIONS COLLECTION
    // ══════════════════════════════════════════
    match /submissions/{submissionId} {
      // Team can create submissions
      allow create: if request.auth != null
        && request.resource.data.keys().hasAll(['sessionId', 'challengeId', 'answer', 'submittedAt', 'status'])
        && request.resource.data.status == 'pending';

      // Team can read their own submission results
      allow read: if request.auth != null;

      // Only Cloud Functions update submission results
      allow update: if false;
      allow delete: if false;
    }

    // ══════════════════════════════════════════
    // EVENT CONFIG (read-only for clients)
    // ══════════════════════════════════════════
    match /event_config/{configId} {
      allow read: if request.auth != null;
      allow write: if false; // Admin only via console/SDK
    }
  }
}

